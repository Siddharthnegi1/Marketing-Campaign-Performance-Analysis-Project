      <aliases enabled='yes' />
      <column caption='Acquisition Cost' datatype='real' name='[Acquisition_Cost]' role='measure' type='quantitative' />
      <column caption='Click-Through Rate (CTR)' datatype='real' name='[Calculation_0282898733252611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Clicks]) / SUM([Impressions])' />
      </column>
      <column caption='Conversion Rate (CR)' datatype='real' name='[Calculation_0282898742636548]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Conversions]) / SUM([Clicks])' />
      </column>
      <column caption='Cost Per Acquisition (CPA)' datatype='real' name='[Calculation_0282898742861829]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Acquisition_Cost]) / SUM([Conversions])' />
      </column>
      <column caption='Revenue Per Lead' datatype='real' name='[Calculation_0282898743009286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / SUM([Leads])' />
      </column>
      <column caption='Channel Count' datatype='integer' name='[Calculation_1160046251180036]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LEN([Channel_Used]) - LEN(REPLACE([Channel_Used], &quot;,&quot;, &quot;&quot;)) + 1' />
      </column>
      <column caption='Revenue per Channel' datatype='real' name='[Calculation_1160046251970565]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Revenue] / [Calculation_1160046251180036]' />
      </column>
      <column caption='YouTube' datatype='real' name='[Calculation_1160046253125639]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;YouTube&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
      </column>
      <column caption='Facebook' datatype='real' name='[Calculation_1160046253338632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;Facebook&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
      </column>
      <column caption='Instagram' datatype='real' name='[Calculation_1160046253576201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;Instagram&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
      </column>
      <column caption='Google' datatype='real' name='[Calculation_1160046253682698]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;Google&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
      </column>
      <column caption='WhatsApp' datatype='real' name='[Calculation_1160046253805579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;WhatsApp&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
      </column>
      <column caption='Email' datatype='real' name='[Calculation_1160046253907980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Channel_Used], &quot;Email&quot;)&#13;&#10;THEN [Calculation_1160046251970565]&#13;&#10;END' />
